# Server configuration
NODE_ENV=production
PORT=3000

# File storage paths (inside Docker volume)
VAULT_ROOT=/data/vault
TRASH_PATH=/data/trash
DB_PATH=/data/state.db

# Maximum file size in MB
MAX_FILE_SIZE_MB=100

# Security secrets
# Generate with: openssl rand -hex 32
API_KEY=
JWT_SECRET=

# Admin user (single-user setup)
ADMIN_EMAIL=enzoamabile@gmail.com
# Generate with: node -e "require('bcrypt').hash('YOUR_PASSWORD',12,(_,h)=>console.log(h))"
ADMIN_PASSWORD_HASH=
